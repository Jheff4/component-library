{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"declaration": true,
		"declarationDir": "dist/types",
		"rootDir": "src",
		"types": []
	},
	"include": ["src"],
	"exclude": [
		"dist",
		"node_modules",
		".storybook",
		"**/*.stories.ts",
		"**/*.stories.tsx",
		"**/*.test.ts",
		"**/*.test.tsx"
	]
}